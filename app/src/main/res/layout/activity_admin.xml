<?xml version="1.0" encoding="utf-8"?>
<!--
    ADMIN FINDER / SCANNER LAYOUT (activity_admin.xml)
    FIXES:
    1. ListView → RecyclerView (ListView is deprecated, poor performance)
    2. Floating action button replaces ImageView used as FAB
    3. Hint text uses empty state properly
    4. ProgressBar → LinearProgressIndicator
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- TOP BAR -->
        <LinearLayout
            android:id="@+id/topbar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:background="@color/colorTopBar"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="8dp"
            android:elevation="4dp">

            <ImageView
                android:id="@+id/back"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:padding="10dp"
                android:src="@drawable/ic_arrow_back"
                android:contentDescription="@string/action_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:tint="@color/colorOnPrimary" />

            <TextView
                android:id="@+id/activityname"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/title_admin_finder"
                android:textColor="@color/colorOnPrimary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingStart="8dp"
                android:maxLines="1"
                android:ellipsize="end" />

            <ImageView
                android:id="@+id/note"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:padding="10dp"
                android:src="@drawable/ic_note"
                android:contentDescription="Notes"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:tint="@color/colorSecondary" />
        </LinearLayout>

        <!-- URL Input -->
        <LinearLayout
            android:id="@+id/inputlayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/colorSurface"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="4dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">

            <EditText
                android:id="@+id/urlfield"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/bg_url_field"
                android:textColor="@color/colorOnSurface"
                android:textColorHint="@color/colorHint"
                android:textSize="13sp"
                android:hint="@string/admin_hint"
                android:maxLines="1"
                android:inputType="textUri"
                android:imeOptions="actionGo"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/find"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/action_go"
                android:textColor="@color/colorSecondary"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Progress -->
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progressbar"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:indeterminate="true"
            android:visibility="gone"
            app:indicatorColor="@color/colorSecondary"
            app:trackColor="@color/colorSurface" />

        <!-- Results area -->
        <FrameLayout
            android:id="@+id/layout"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- FIX: RecyclerView replaces deprecated ListView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/listview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="72dp"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            <!-- Empty state -->
            <TextView
                android:id="@+id/hinttext"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:padding="24dp"
                android:text="@string/admin_no_results"
                android:textColor="@color/colorOnSurfaceVariant"
                android:textSize="14sp"
                android:visibility="visible" />
        </FrameLayout>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
