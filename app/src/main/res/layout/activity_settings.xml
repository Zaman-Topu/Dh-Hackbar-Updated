<?xml version="1.0" encoding="utf-8"?>
<!--
    SETTINGS ACTIVITY LAYOUT
    FIXES:
    1. Switch (deprecated widget.Switch) → SwitchMaterial (AndroidX)
    2. Hardcoded heights and padding → proper dimension values
    3. Dividers → Material dividers (View with colorDivider)
    4. All "Fuck" placeholder texts removed
    5. paddingLeft/Right → paddingStart/End
-->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/background"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ======== TOP BAR ======== -->
        <LinearLayout
            android:id="@+id/topbar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:background="@color/colorTopBar"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="8dp"
            android:elevation="4dp">

            <ImageView
                android:id="@+id/back"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:padding="10dp"
                android:src="@drawable/ic_arrow_back"
                android:contentDescription="@string/action_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:tint="@color/colorOnPrimary" />

            <TextView
                android:id="@+id/activityname"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/title_settings"
                android:textColor="@color/colorOnPrimary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingStart="8dp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- ======== DIVIDER ======== -->
        <View android:id="@+id/hr0" android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/colorDivider" />

        <!-- ======== SAVE LAST URL ======== -->
        <LinearLayout
            android:id="@+id/savelasturllinear"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:padding="16dp">

            <LinearLayout
                android:id="@+id/savelasturlverticallinear"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/savelasturlsetting"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/setting_save_last_url"
                    android:textColor="@color/colorOnSurface"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/savelasturldetails"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/setting_save_last_url_desc"
                    android:textColor="@color/colorOnSurfaceVariant"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- FIX: Switch → SwitchMaterial (AndroidX) -->
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/savelasturlswitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="16dp" />
        </LinearLayout>

        <View android:id="@+id/hr1" android:layout_width="match_parent" android:layout_height="1dp"
            android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
            android:background="@color/colorDivider" />

        <!-- ======== TEXT SIZE ======== -->
        <LinearLayout
            android:id="@+id/textsizelinear"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:padding="16dp">

            <LinearLayout
                android:id="@+id/textsizeverticallinear"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/textsizesetting"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/setting_text_size"
                    android:textColor="@color/colorOnSurface"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/textsizedetails"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/setting_text_size_desc"
                    android:textColor="@color/colorOnSurfaceVariant"
                    android:textSize="12sp" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/textsizeseekbar"
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="16dp"
                android:max="3"
                android:progress="1"
                android:progressTint="@color/colorSecondary"
                android:thumbTint="@color/colorSecondary" />
        </LinearLayout>

        <View android:id="@+id/hr2" android:layout_width="match_parent" android:layout_height="1dp"
            android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
            android:background="@color/colorDivider" />

        <!-- ======== VIEW SOURCE METHOD ======== -->
        <LinearLayout
            android:id="@+id/viewsourcelinear"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:padding="16dp">

            <TextView
                android:id="@+id/viewsourcesetting"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/setting_view_source_method"
                android:textColor="@color/colorOnSurface"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/viewsourcemethod"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:textColor="@color/colorSecondary"
                android:textSize="14sp" />
        </LinearLayout>

        <View android:id="@+id/hr3" android:layout_width="match_parent" android:layout_height="1dp"
            android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
            android:background="@color/colorDivider" />

        <!-- ======== CLEAR DATA ======== -->
        <TextView
            android:id="@+id/cleardatasetting"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:padding="16dp"
            android:text="@string/setting_clear_data"
            android:textColor="@color/colorError"
            android:textSize="16sp" />

        <View android:id="@+id/hr4" android:layout_width="match_parent" android:layout_height="1dp"
            android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
            android:background="@color/colorDivider" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
